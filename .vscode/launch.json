{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Windows Launch",
      "program": "${workspaceFolder}/out/main.exe",
      "type": "cppvsdbg",
      "request": "launch",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "c:/Users/Jeff/Desktop/CS/vulkan-template/src",
      "program": "c:/Users/Jeff/Desktop/CS/vulkan-template/src/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}